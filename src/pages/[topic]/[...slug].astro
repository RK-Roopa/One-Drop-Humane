---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

const topicLabels: Record<string, string> = {
  'peak-performance': 'Peak Performance',
  'entrepreneurship': 'Entrepreneurship',
  'workplace-culture': 'Workplace Culture',
  'personal-growth': 'Personal Growth',
  'purpose-identity': 'Purpose & Identity',
  'leadership': 'Leadership',
};

export async function getStaticPaths() {
  const allPaths = [];
  const cols = [
    'peak-performance',
    'entrepreneurship',
    'workplace-culture',
    'personal-growth',
    'purpose-identity',
    'leadership',
  ];
  for (const col of cols) {
    const entries = await getCollection(col as any);
    for (const entry of entries) {
      allPaths.push({
        params: { topic: col, slug: entry.id },
        props: { entry, col },
      });
    }
  }
  return allPaths;
}

const { topic } = Astro.params;
const { entry, col } = Astro.props;
const { Content } = await render(entry);
const label = topicLabels[topic] || topic;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${entry.data.title} — One Drop Humane`}
      description={entry.data.description}
    />
  </head>
  <body>
    <Header />
    <main>
      <article class="essay">
        <div class="essay-meta">
          <a href={`/topics/${topic}`} class="back">← {label}</a>
          <time>
            {new Date(entry.data.date).toLocaleDateString('en-US', {
              year: 'numeric', month: 'long', day: 'numeric'
            })}
          </time>
        </div>

        <h1>{entry.data.title}</h1>
        <p class="description">{entry.data.description}</p>

        <div class="essay-body">
          <Content />
        </div>

        <div class="essay-footer">
          <a href={`/topics/${topic}`} class="back-link">← Back to {label}</a>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  .essay {
    max-width: 680px;
    margin: 60px auto 100px;
    padding: 0 24px;
  }

  .essay-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
  }

  .back {
    font-size: 0.9rem;
    color: #888;
    text-decoration: none;
    transition: color 0.2s;
  }

  .back:hover {
    color: #111;
  }

  time {
    font-size: 0.85rem;
    color: #aaa;
  }

  h1 {
    font-size: 2.2rem;
    line-height: 1.2;
    color: #111;
    margin-bottom: 16px;
  }

  .description {
    font-size: 1.05rem;
    color: #888;
    line-height: 1.6;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid #eee;
  }

  .essay-body {
    font-size: 22px;
    line-height: 2;
    color: #333;
    font-family: 'KyoboHandwriting', cursive;
  }

  .essay-body p {
    margin-bottom: 24px;
  }

  .essay-body h2 {
    font-size: 1.4rem;
    margin: 48px 0 16px;
    color: #111;
  }

  .essay-body h3 {
    font-size: 1.15rem;
    margin: 32px 0 12px;
    color: #111;
  }

  .essay-footer {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid #eee;
  }

  .back-link {
    font-size: 0.9rem;
    color: #888;
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #111;
  }
</style>
