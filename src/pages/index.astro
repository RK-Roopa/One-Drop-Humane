---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SITE_TITLE = "One Drop Humane";
const SITE_DESCRIPTION = "A knowledge repository for founders and leaders exploring peak performance, culture, entrepreneurship, and purposeful living.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>A repository for those who lead with intention.</h1>
        <p>Explore years of lived experience and reflection across the ideas that matter most to founders, leaders, and anyone building something meaningful.</p>
        <a href="/topics" class="cta">Explore the Topics →</a>
      </section>

      <section class="topics-grid">
        <h2>What You'll Find Here</h2>
        <div class="grid">
          <a href="/topics/peak-performance" class="topic-card">
            <h3>Peak Performance</h3>
            <p>How leaders operate at their best without burning out.</p>
          </a>
          <a href="/topics/entrepreneurship" class="topic-card">
            <h3>Entrepreneurship</h3>
            <p>The real terrain of building something from nothing.</p>
          </a>
          <a href="/topics/workplace-culture" class="topic-card">
            <h3>Workplace Culture</h3>
            <p>What it takes to build environments where people thrive.</p>
          </a>
          <a href="/topics/personal-growth" class="topic-card">
            <h3>Personal Growth</h3>
            <p>The inner work that makes the outer work possible.</p>
          </a>
          <a href="/topics/purpose-identity" class="topic-card">
            <h3>Purpose & Identity</h3>
            <p>Who you are beneath the role, the title, the hustle.</p>
          </a>
          <a href="/topics/leadership" class="topic-card">
            <h3>Leadership</h3>
            <p>Honest reflections on what it means to guide others.</p>
          </a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    max-width: 680px;
    margin: 80px auto;
    padding: 0 24px;
    text-align: center;
  }

  .hero h1 {
    font-size: 2.4rem;
    line-height: 1.2;
    margin-bottom: 24px;
  }

  .hero p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #555;
    margin-bottom: 32px;
  }

  .cta {
    display: inline-block;
    padding: 12px 28px;
    background: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }

  .topics-grid {
    max-width: 960px;
    margin: 80px auto;
    padding: 0 24px;
  }

  .topics-grid h2 {
    font-size: 1.4rem;
    margin-bottom: 32px;
    text-align: center;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
  }

  .topic-card {
    padding: 28px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }

  .topic-card:hover {
    border-color: #000;
    transform: translateY(-2px);
  }

  .topic-card h3 {
    font-size: 1.1rem;
    margin-bottom: 8px;
  }

  .topic-card p {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.5;
  }
</style>
