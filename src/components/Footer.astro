<footer>
  <div class="footer-inner">
    <span class="footer-name">One Drop Humane</span>
    <span class="footer-copy">A knowledge repository for founders and leaders.</span>
    <span class="footer-year">© {new Date().getFullYear()}</span>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid #eee;
    padding: 40px 24px;
    margin-top: 40px;
  }

  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-name {
    font-weight: 700;
    font-size: 0.9rem;
    color: #111;
    min-width: 160px;
  }

  .footer-copy {
    font-size: 0.85rem;
    color: #888;
    text-align: center;
    flex: 1;
  }

  .footer-year {
    font-size: 0.85rem;
    color: #bbb;
    min-width: 60px;
    text-align: right;
  }
</style>
