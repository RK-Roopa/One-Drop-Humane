<header>
  <nav>
    <a href="/" class="site-name">One Drop Humane</a>
    <div class="nav-links">
      <a href="/topics">Topics</a>
      <a href="/about">About</a>
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #eee;
    z-index: 100;
  }

  nav {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-name {
    font-size: 1rem;
    font-weight: 700;
    color: #111;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 32px;
  }

  .nav-links a {
    font-size: 0.9rem;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: #111;
  }
</style>
